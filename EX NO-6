#include <stack>
#include <unordered_set>
using namespace std;

string removeDuplicates(string s) {
    stack<char> st;
    unordered_set<char> seen;

    for (char c : s) {
        if (seen.find(c) == seen.end()) {
            st.push(c);
            seen.insert(c);
        }
    }

    string result = "";
    while (!st.empty()) {
        result = st.top() + result;
        st.pop();
    }

    return result;
}
