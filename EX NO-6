#include <iostream>
#include <stack>
#include <unordered_map>
using namespace std;

bool isValid(string s) {
    stack<char> st;

    unordered_map<char, char> mp = {
        {')', '('},
        {'}', '{'},
        {']', '['}
    };

    for (char c : s) {
        if (mp.count(c)) {  // if closing bracket
            if (st.empty() || st.top() != mp[c])
                return false;
            st.pop();
        } else {
            st.push(c);
        }
    }

    return st.empty();
}

int main() {
    string s = "{[()]}";
    cout << (isValid(s) ? "Valid" : "Invalid");
}
